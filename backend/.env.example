# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
TRUST_PROXY=0

# MongoDB
MONGO_URI=mongodb://localhost:27017/srimurugan_tours

# JWT
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here_change_in_production
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your_email@gmail.com
SMTP_SECURE=auto
SMTP_REQUIRE_TLS=true
SMTP_FALLBACK_PORTS=465
SMTP_CONNECTION_TIMEOUT=10000
SMTP_GREETING_TIMEOUT=10000
SMTP_SOCKET_TIMEOUT=15000

# Optional Email Provider Fallback (recommended for production hosting)
EMAIL_PROVIDER=auto
RESEND_API_KEY=
RESEND_FROM=

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_SECRET=your_razorpay_secret

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key

# File Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880
